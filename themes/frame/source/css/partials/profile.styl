.profile
    margin-top $margin-primary
    display flex
    flex-direction row-reverse

    .profile-content
        flex 1
        margin 0 $margin-l-0 0 0

        .profile-title
            margin-top 0
            margin-bottom $margin-m-0

        .profile-body
            margin-top 0
            margin-bottom $margin-l-1

        .profile-title
            text-style(heading-h1)

        .profile-body
            text-style(body-default)

        .profile-link
            margin-top 0
            margin-bottom $margin-m-1
            text-style(header)


    .profile-image
        width calc(50% * var(--shader-scale, 1))
        overflow hidden
        border-radius 12px
        box-shadow 0 8px 32px var(--shader-shadow-color, rgba(180, 100, 50, 0.4))
        transition box-shadow 0.3s ease

        canvas
            display block
            width 100%
            aspect-ratio 3 / 2

@media (max-width: 480px)
    .profile
        flex-wrap wrap

        .profile-content
            width 100%
            margin-top $margin-m-1

        .profile-image
            width 100%
