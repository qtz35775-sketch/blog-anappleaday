    <category term="archives" scheme="https://anappleaday.top/archives/"/>
    <category term="测试" scheme="https://anappleaday.top/tags/%E6%B5%8B%E8%AF%95/"/>
    <category term="Frame主题" scheme="https://anappleaday.top/tags/Frame%E4%B8%BB%E9%A2%98/"/>
